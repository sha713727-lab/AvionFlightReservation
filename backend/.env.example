NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# PostgreSQL connection string
# Default local embedded DB (npm run db:local): port 5433
# Docker Compose / system Postgres: port 5432
# Optional pool tuning: append &connection_limit=10&pool_timeout=10
DATABASE_URL=postgresql://avion:avion@localhost:5433/avion_flight?schema=public&connection_limit=10

# Comma-separated frontend origins (no wildcards)
CORS_ORIGINS=http://localhost:3000

# Rate limits
# General: all routes (default 100 / 15 minutes)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
# Heavy: applied to catalog detail routes (GET /:slug) — 10 / minute
HEAVY_RATE_LIMIT_MAX=10
HEAVY_RATE_LIMIT_WINDOW_MS=60000

# Redis is REQUIRED when NODE_ENV=production (shared rate limits + catalog cache)
# Leave empty for local/dev in-memory stores
# Docker Compose Redis: redis://localhost:6379
REDIS_URL=

# Pagination defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Security / ops toggles
# Set ENABLE_COMPRESSION=false if Node/undici clients fail with ERR_CONTENT_DECODING_FAILED
ENABLE_COMPRESSION=true
# Swagger UI is never enabled when NODE_ENV=production
ENABLE_SWAGGER=true
# TRUST_PROXY=true ONLY behind a trusted reverse proxy (nginx/Caddy).
# If the API is exposed directly, keep false so clients cannot spoof X-Forwarded-For.
TRUST_PROXY=false
# Catalog response cache (memory locally, Redis in production)
ENABLE_CATALOG_CACHE=true
CATALOG_CACHE_MAX_AGE_SECONDS=60
