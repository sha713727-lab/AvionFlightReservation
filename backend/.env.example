NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# PostgreSQL connection string
# Default local embedded DB (npm run db:local): port 5433
# Docker Compose / system Postgres: port 5432
DATABASE_URL=postgresql://avion:avion@localhost:5433/avion_flight?schema=public

# Comma-separated frontend origins (no wildcards)
CORS_ORIGINS=http://localhost:3000

# Rate limits
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
HEAVY_RATE_LIMIT_MAX=10
HEAVY_RATE_LIMIT_WINDOW_MS=60000

# Pagination defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
