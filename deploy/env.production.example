# Copy to deploy/.env.production on the VPS (never commit real secrets).
# cp deploy/env.production.example deploy/.env.production

NODE_ENV=production
DOMAIN=aviosupportdesk.com

# Strong random values — generate on the server:
# openssl rand -hex 24
POSTGRES_USER=avion
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=avion_flight

REDIS_URL=redis://redis:6379

# Public URLs (USA / Canada production)
NEXT_PUBLIC_SITE_URL=https://aviosupportdesk.com
NEXT_PUBLIC_API_URL=https://aviosupportdesk.com

# Server-side only — Next SSR talks to API over Docker network (avoids hairpin lag)
# Set automatically in docker-compose.prod.yml as http://api:4000

CORS_ORIGINS=https://aviosupportdesk.com,https://www.aviosupportdesk.com
TRUST_PROXY=true
ENABLE_COMPRESSION=true
ENABLE_SWAGGER=false
ENABLE_CATALOG_CACHE=true
CATALOG_CACHE_MAX_AGE_SECONDS=600

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
HEAVY_RATE_LIMIT_MAX=10
HEAVY_RATE_LIMIT_WINDOW_MS=60000

DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
LOG_LEVEL=info

# First seed only — set false after initial deploy
ALLOW_DESTRUCTIVE_SEED=true

# Let's Encrypt
CERTBOT_EMAIL=sales@avionflightreservation.com
